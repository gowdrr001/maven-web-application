node {
    echo "The Node Name is : ${env.NODE_NAME}"
    echo "The Job Name is : ${env.JOB_NAME}"
    echo "The BUILD Number is : ${env.BUILD_NUMBER}"
    def mavenHome = tool name: "maven3.8.5"
    stage("Checkout") {
        git credentialsId: 'github', url: 'https://github.com/gowdrr001/maven-web-application.git'
    }
    stage("Build") {
        sh "${mavenHome}/bin/mvn clean package"
    }
    // sorany qube genration
    stage("sonarQube Report") {
        sh "${mavenHome}/bin/mvn sonar:sonar"
    }
    // upload  qube genration
    stage("nexus upload") {
        sh "${mavenHome}/bin/mvn deploy"
    }    
    stage("Deploy Apache") {
        sshagent(['node3_ssh_key']) {
            sh "scp -o StrictHostKeyChecking=no ${WORKSPACE}/target/maven-web-application.war node3@192.168.60.131:/home/node3/softwares/apache-tomcat-9.0.115/webapps/"
        }
    }    
}
